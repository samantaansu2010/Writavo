# ─── DATABASE (required) ───────────────────────────────────────────────────────
# Use MONGODB_URI or MONGO_URI (Railway uses MONGO_URI)
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/writavo?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://...  # Alternative; both are supported

# ─── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Bind host — keep 0.0.0.0 for Railway/Docker (do NOT change to localhost)
HOST=0.0.0.0

# ─── JWT / AUTH ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS / FRONTEND ───────────────────────────────────────────────────────────
# Set to your Railway app URL after first deploy, or * to allow all origins
CORS_ORIGIN=*
# For local dev use http://localhost:5000 (or your PORT)
FRONTEND_URL=http://localhost:5000

# ─── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# Set to true and fill in credentials to enable "Sign in with Google"
ENABLE_GOOGLE_AUTH=false
# Get credentials at: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match what you set in Google Console → Authorized redirect URIs
GOOGLE_CALLBACK_URL=https://YOUR-APP.up.railway.app/api/auth/google/callback

# ─── EMAIL ─────────────────────────────────────────────────────────────────────
# Leave blank in development — emails are logged to console instead
ENABLE_EMAIL_VERIFICATION=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
# Use a Gmail App Password (NOT your regular password)
# Enable at: https://myaccount.google.com → Security → App passwords
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM="Writavo <hello@writavo.com>"

# ─── FILE UPLOADS ──────────────────────────────────────────────────────────────
# Folder for user uploads (relative to backend/)
UPLOAD_DIR=./uploads
# Max file size in bytes (default 10MB)
MAX_FILE_SIZE=10485760

# ─── RATE LIMITING ─────────────────────────────────────────────────────────────
# Max requests per 15-minute window per IP
RATE_LIMIT_MAX=200
